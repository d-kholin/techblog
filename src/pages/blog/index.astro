---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Lab Notes — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />

		<div class="page-header">
			<div class="page-header-inner">
				<p class="page-eyebrow">// lab notes</p>
				<h1 class="page-title">All posts</h1>
				<p class="page-subtitle">{posts.length} thing{posts.length !== 1 ? 's' : ''} written down so I don't forget them</p>
			</div>
		</div>

		<main>
			{posts.length === 0 ? (
				<p class="empty-state">Nothing here yet — check back soon.</p>
			) : (
				<ul class="posts-list">
					{posts.map((post, i) => (
						<li class={`post-item ${i === 0 ? 'post-item--featured' : ''}`}>
							<a href={`/blog/${post.id}/`} class="post-link">
								{i === 0 && post.data.heroImage && (
									<div class="post-image">
										<Image width={960} height={400} src={post.data.heroImage} alt="" />
									</div>
								)}
								{i !== 0 && post.data.heroImage && (
									<div class="post-image-thumb">
										<Image width={280} height={160} src={post.data.heroImage} alt="" />
									</div>
								)}
								<div class="post-content">
									<div class="post-meta">
										<span class="post-num">{String(i + 1).padStart(2, '0')} —</span>
										<FormattedDate date={post.data.pubDate} />
									</div>
									<h2 class="post-title">{post.data.title}</h2>
									{post.data.description && (
										<p class="post-excerpt">{post.data.description}</p>
									)}
									<span class="post-cta">read it →</span>
								</div>
							</a>
						</li>
					))}
				</ul>
			)}
		</main>

		<Footer />
	</body>
</html>

<style>
	/* Page header */
	.page-header {
		background: var(--bg-raised);
		border-bottom: 1px solid var(--border);
		padding: 3em 1.5em 2.5em;
	}
	.page-header-inner {
		width: 100%;
		max-width: 760px;
		margin: 0 auto;
		box-sizing: border-box;
	}
	.page-eyebrow {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.72rem;
		color: var(--text-3);
		margin: 0 0 0.75em;
		letter-spacing: 0.02em;
	}
	.page-title {
		font-family: 'Syne', system-ui, sans-serif;
		font-size: clamp(2rem, 6vw, 3rem);
		font-weight: 800;
		color: var(--text-1);
		margin: 0 0 0.3em;
		letter-spacing: -0.03em;
	}
	.page-subtitle {
		font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
		font-size: 0.88rem;
		color: var(--text-3);
		margin: 0;
	}

	/* List */
	main {
		width: 100%;
		max-width: 760px;
		margin: 0 auto;
		padding: 3em 1.5em 2em;
		box-sizing: border-box;
	}
	.empty-state {
		text-align: center;
		color: var(--text-3);
		padding: 4em 0;
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.85rem;
	}
	.posts-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0;
	}

	.post-item {
		border-bottom: 1px solid var(--border);
	}
	.post-link {
		display: flex;
		gap: 1.5em;
		align-items: flex-start;
		padding: 2em 0;
		text-decoration: none;
		color: inherit;
		transition: background 0.15s ease;
	}
	.post-link:hover {
		color: inherit;
	}
	.post-link:hover .post-title {
		color: var(--amber);
	}
	.post-link:hover .post-cta {
		color: var(--amber);
	}

	/* Featured (first) post */
	.post-item--featured .post-link {
		flex-direction: column;
		gap: 1em;
		padding: 2em 0 2.5em;
	}
	.post-item--featured .post-title {
		font-size: 1.75rem;
	}
	.post-item--featured .post-excerpt {
		-webkit-line-clamp: 3;
	}

	/* Images */
	.post-image {
		width: 100%;
		overflow: hidden;
		border-radius: 6px;
		border: 1px solid var(--border);
	}
	.post-image img {
		width: 100%;
		height: 340px;
		object-fit: cover;
		border-radius: 6px;
		display: block;
		transition: transform 0.35s ease;
	}
	.post-link:hover .post-image img {
		transform: scale(1.015);
	}
	.post-image-thumb {
		flex-shrink: 0;
		width: 180px;
		border-radius: 5px;
		overflow: hidden;
		border: 1px solid var(--border);
		align-self: flex-start;
	}
	.post-image-thumb img {
		width: 100%;
		height: 110px;
		object-fit: cover;
		border-radius: 5px;
		display: block;
	}

	/* Post content */
	.post-content {
		flex: 1;
		min-width: 0;
		display: flex;
		flex-direction: column;
		gap: 0.45em;
	}
	.post-meta {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.68rem;
		color: var(--text-3);
		letter-spacing: 0.03em;
		display: flex;
		align-items: center;
		gap: 0.4em;
	}
	.post-num {
		color: var(--amber);
		opacity: 0.6;
	}
	.post-title {
		font-family: 'Syne', system-ui, sans-serif;
		font-size: 1.2rem;
		font-weight: 700;
		color: var(--text-1);
		line-height: 1.2;
		margin: 0;
		letter-spacing: -0.02em;
		transition: color 0.15s ease;
	}
	.post-excerpt {
		font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
		font-size: 0.875rem;
		color: var(--text-2);
		line-height: 1.65;
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.post-cta {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.7rem;
		color: var(--text-3);
		margin-top: 0.4em;
		display: inline-block;
		transition: color 0.15s ease;
	}

	@media (max-width: 600px) {
		.post-link {
			flex-direction: column;
			gap: 0.75em;
		}
		.post-image-thumb {
			width: 100%;
		}
		.post-image-thumb img {
			height: 180px;
			width: 100%;
		}
		.post-item--featured .post-title {
			font-size: 1.4rem;
		}
	}
</style>
