---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 4);

const stack = [
	'Microsoft 365', 'Intune', 'AWS',
	'Kubernetes', 'GitOps', 'Terraform', 'CI/CD Pipelines',
	'PowerShell', 'GitHub Actions', 'Docker',
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />

		<!-- ═══ HERO ═══ -->
		<section class="hero">
			<!-- Background decoration characters -->
			<div class="hero-deco" aria-hidden="true">
				<span class="deco-char deco-1">&#123;&#125;</span>
				<span class="deco-char deco-2">&#47;&#47;</span>
				<span class="deco-char deco-3">&#62;_</span>
			</div>

			<div class="hero-inner">
				<!-- Terminal prompt line -->
				<div class="hero-prompt" aria-hidden="true">
					<span class="prompt-seg prompt-user">michael@lab</span><span class="prompt-seg prompt-sep">:</span><span class="prompt-seg prompt-path">~</span><span class="prompt-seg prompt-dollar"> $</span><span class="prompt-seg prompt-cmd"> whoami</span>
				</div>

				<!-- Status badge -->
				<div class="hero-status">
					<span class="status-dot"></span>
					<span class="status-text">online — probably building something</span>
				</div>

				<!-- Name -->
				<h1 class="hero-name">Hey, I'm<br><em>Michael.</em></h1>

				<!-- Tagline -->
				<p class="hero-tagline">Technology addict. Value maker.<br>Occasional cloud wrangler.</p>

				<!-- Description -->
				<p class="hero-desc">
					Things I've automated, broken, fixed at 2am, and finally understood.
					If it runs on AWS, talks to Entra, or has an api — it's fair game.
				</p>

				<!-- Typing line -->
				<div class="hero-typer">
					<span class="typer-label" aria-hidden="true">// currently digging into →</span>
					<span class="terminal-typed" aria-live="polite"></span><span class="terminal-cursor" aria-hidden="true">▌</span>
				</div>

				<!-- CTAs -->
				<div class="hero-actions">
					<a href="/blog" class="btn-primary">See the lab notes</a>
					<a href="/about" class="btn-ghost">about me →</a>
				</div>
			</div>
		</section>

		<!-- ═══ STACK ═══ -->
		<section class="stack-section">
			<div class="section-wrap">
				<p class="section-eyebrow">// what I work with</p>
				<div class="stack-grid">
					{stack.map(tool => (
						<span class="stack-tag">{tool}</span>
					))}
				</div>
			</div>
		</section>

		<!-- ═══ LAB NOTES ═══ -->
		{posts.length > 0 && (
			<section class="posts-section">
				<div class="section-wrap">
					<div class="posts-header">
						<p class="section-eyebrow">// lab notes</p>
						<a href="/blog" class="see-all">all posts →</a>
					</div>
					<ul class="posts-grid">
						{posts.map((post, i) => (
							<li class={`post-card ${i === 0 ? 'post-card--featured' : ''}`}>
								<a href={`/blog/${post.id}/`} class="post-card-link">
									<div class="post-card-inner">
										<div class="post-card-top">
											<span class="post-index">{String(i + 1).padStart(2, '0')}</span>
											<span class="post-date"><FormattedDate date={post.data.pubDate} /></span>
										</div>
										<h3 class="post-title">{post.data.title}</h3>
										{post.data.description && i === 0 && (
											<p class="post-excerpt">{post.data.description}</p>
										)}
										<span class="post-cta">read it →</span>
									</div>
								</a>
							</li>
						))}
					</ul>
				</div>
			</section>
		)}

		<Footer />
	</body>
</html>

<script>
(function () {
	const words = ['DevOps', 'Microsoft Entra', 'AWS', 'Kubernetes', 'CI/CD Pipelines', 'Azure'];
	const el = document.querySelector('.terminal-typed');
	if (!el) return;
	let wordIndex = 0, charIndex = 0, deleting = false;
	const typeSpeed = 80, deleteSpeed = 45, pauseAfterType = 1900, pauseAfterDelete = 350;

	function tick() {
		const word = words[wordIndex];
		if (!deleting) {
			charIndex++;
			el.textContent = word.slice(0, charIndex);
			if (charIndex === word.length) {
				deleting = true;
				setTimeout(tick, pauseAfterType);
				return;
			}
		} else {
			charIndex--;
			el.textContent = word.slice(0, charIndex);
			if (charIndex === 0) {
				deleting = false;
				wordIndex = (wordIndex + 1) % words.length;
				setTimeout(tick, pauseAfterDelete);
				return;
			}
		}
		setTimeout(tick, deleting ? deleteSpeed : typeSpeed);
	}
	setTimeout(tick, 700);
})();
</script>

<style>
/* ═══ HERO ═══ */
.hero {
	position: relative;
	overflow: hidden;
	background:
		radial-gradient(ellipse 80% 60% at 80% 40%, rgba(194,96,26,0.06) 0%, transparent 65%),
		radial-gradient(ellipse 60% 80% at 10% 80%, rgba(22,128,60,0.03) 0%, transparent 60%),
		var(--bg);
	border-bottom: 1px solid var(--border);
}

/* Background decorative characters */
.hero-deco {
	position: absolute;
	inset: 0;
	pointer-events: none;
	user-select: none;
	overflow: hidden;
}
.deco-char {
	position: absolute;
	font-family: 'JetBrains Mono', monospace;
	font-weight: 700;
	color: rgba(194, 96, 26, 0.06);
	line-height: 1;
}
.deco-1 {
	font-size: clamp(8rem, 18vw, 16rem);
	right: -2%;
	top: -10%;
	letter-spacing: -0.05em;
}
.deco-2 {
	font-size: clamp(5rem, 12vw, 10rem);
	right: 22%;
	bottom: -15%;
	color: rgba(22, 128, 60, 0.04);
}
.deco-3 {
	font-size: clamp(4rem, 8vw, 7rem);
	left: -1%;
	bottom: 5%;
	color: rgba(194, 96, 26, 0.04);
}

.hero-inner {
	position: relative;
	z-index: 2;
	max-width: 860px;
	margin: 0 auto;
	padding: 5em 1.5em 5.5em;
}

/* Prompt line */
.hero-prompt {
	font-family: 'JetBrains Mono', monospace;
	font-size: 0.78rem;
	margin-bottom: 1.5em;
	display: flex;
	align-items: center;
	gap: 0;
	flex-wrap: wrap;
}
.prompt-user { color: var(--green); }
.prompt-sep  { color: var(--text-3); }
.prompt-path { color: var(--amber); }
.prompt-dollar { color: var(--text-3); }
.prompt-cmd  { color: var(--text-2); }

/* Status badge */
.hero-status {
	display: inline-flex;
	align-items: center;
	gap: 0.5em;
	padding: 0.3em 0.85em;
	border: 1px solid var(--border-2);
	border-radius: 100px;
	background: var(--bg-card);
	font-family: 'JetBrains Mono', monospace;
	font-size: 0.7rem;
	color: var(--text-2);
	margin-bottom: 1.5em;
}
.status-dot {
	width: 6px;
	height: 6px;
	border-radius: 50%;
	background: var(--green);
	flex-shrink: 0;
	animation: pulse-dot 2.5s ease-in-out infinite;
}
@keyframes pulse-dot {
	0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(110, 231, 183, 0.4); }
	50%       { opacity: 0.8; box-shadow: 0 0 0 4px rgba(110, 231, 183, 0); }
}

/* Name */
.hero-name {
	font-family: 'Syne', system-ui, sans-serif;
	font-size: clamp(3rem, 8vw, 5.5rem);
	font-weight: 800;
	line-height: 1.0;
	letter-spacing: -0.035em;
	color: var(--text-1);
	margin: 0 0 0.45em;
}
.hero-name em {
	font-style: normal;
	color: var(--amber);
}

/* Tagline */
.hero-tagline {
	font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
	font-size: clamp(1rem, 2.5vw, 1.2rem);
	font-weight: 300;
	color: var(--text-2);
	line-height: 1.6;
	margin: 0 0 1em;
}

/* Description */
.hero-desc {
	font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
	font-size: 0.95rem;
	line-height: 1.8;
	color: var(--text-3);
	max-width: 520px;
	margin: 0 0 2em;
}

/* Typing animation row */
.hero-typer {
	display: flex;
	align-items: center;
	gap: 0.6em;
	font-family: 'JetBrains Mono', monospace;
	font-size: 0.8rem;
	margin-bottom: 2.5em;
	flex-wrap: wrap;
}
.typer-label {
	color: var(--text-3);
}
.terminal-typed {
	color: var(--amber);
	min-width: 2ch;
}
.terminal-cursor {
	color: var(--amber);
	animation: blink-cursor 1s step-end infinite;
	font-weight: 300;
}
@keyframes blink-cursor {
	0%, 100% { opacity: 1; }
	50%       { opacity: 0; }
}

/* CTAs */
.hero-actions {
	display: flex;
	align-items: center;
	gap: 1em;
	flex-wrap: wrap;
}
.btn-primary {
	display: inline-flex;
	align-items: center;
	padding: 0.65em 1.5em;
	background: var(--amber);
	color: #0c0a07;
	font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
	font-size: 0.9rem;
	font-weight: 600;
	text-decoration: none;
	border-radius: 6px;
	transition: background 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease;
}
.btn-primary:hover {
	background: var(--amber-light);
	color: #0c0a07;
	transform: translateY(-1px);
	box-shadow: 0 6px 20px rgba(249,115,22,0.35);
}
.btn-ghost {
	display: inline-flex;
	align-items: center;
	padding: 0.65em 1.2em;
	background: transparent;
	color: var(--text-2);
	font-family: 'JetBrains Mono', monospace;
	font-size: 0.82rem;
	font-weight: 400;
	text-decoration: none;
	border-radius: 6px;
	border: 1px solid var(--border-2);
	transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease;
}
.btn-ghost:hover {
	color: var(--amber);
	border-color: rgba(249, 115, 22, 0.4);
	background: var(--amber-glow);
}

/* ═══ SHARED SECTION STYLES ═══ */
.section-wrap {
	max-width: 1040px;
	margin: 0 auto;
	padding: 0 1.5em;
}
.section-eyebrow {
	font-family: 'JetBrains Mono', monospace;
	font-size: 0.72rem;
	color: var(--text-3);
	margin: 0 0 1.25em;
	letter-spacing: 0.02em;
}

/* ═══ STACK ═══ */
.stack-section {
	padding: 3.5em 0;
	border-bottom: 1px solid var(--border);
}
.stack-grid {
	display: flex;
	flex-wrap: wrap;
	gap: 0.5em;
}
.stack-tag {
	font-family: 'JetBrains Mono', monospace;
	font-size: 0.72rem;
	padding: 0.35em 0.8em;
	border: 1px solid var(--border-2);
	border-radius: 4px;
	color: var(--text-2);
	background: var(--bg-card);
	cursor: default;
	transition: color 0.15s, border-color 0.15s, background 0.15s, transform 0.1s;
}
.stack-tag:hover {
	color: var(--amber);
	border-color: rgba(249, 115, 22, 0.35);
	background: var(--amber-glow);
	transform: translateY(-1px);
}

/* ═══ POSTS ═══ */
.posts-section {
	padding: 3.5em 0 5em;
}
.posts-header {
	display: flex;
	align-items: center;
	justify-content: space-between;
	margin-bottom: 1.5em;
}
.see-all {
	font-family: 'JetBrains Mono', monospace;
	font-size: 0.72rem;
	color: var(--text-3);
	text-decoration: none;
	transition: color 0.15s ease;
}
.see-all:hover {
	color: var(--amber);
}

/* Post grid: featured (full width) + 3-col below */
.posts-grid {
	list-style: none;
	margin: 0;
	padding: 0;
	display: grid;
	grid-template-columns: repeat(3, 1fr);
	gap: 1px;
	border: 1px solid var(--border);
	border-radius: 8px;
	overflow: hidden;
	background: var(--border);
}

.post-card {
	background: var(--bg-card);
	transition: background 0.2s ease;
}
.post-card:hover {
	background: var(--bg-card-2);
}
.post-card--featured {
	grid-column: 1 / -1;
	border-bottom: 1px solid var(--border);
}

.post-card-link {
	display: block;
	text-decoration: none;
	color: inherit;
	height: 100%;
}
.post-card-inner {
	padding: 1.75em 2em;
	display: flex;
	flex-direction: column;
	gap: 0.6em;
	height: 100%;
}

/* Featured card gets slightly more spacious layout */
.post-card--featured .post-card-inner {
	padding: 2.25em 2.5em;
}

.post-card-top {
	display: flex;
	align-items: center;
	gap: 1em;
}
.post-index {
	font-family: 'JetBrains Mono', monospace;
	font-size: 0.65rem;
	font-weight: 500;
	color: var(--amber);
	opacity: 0.7;
	letter-spacing: 0.05em;
}
.post-date {
	font-family: 'JetBrains Mono', monospace;
	font-size: 0.65rem;
	color: var(--text-3);
	letter-spacing: 0.03em;
}
.post-title {
	font-family: 'Syne', system-ui, sans-serif;
	font-size: 1.1rem;
	font-weight: 700;
	color: var(--text-1);
	line-height: 1.25;
	margin: 0;
	letter-spacing: -0.02em;
	transition: color 0.15s ease;
}
.post-card--featured .post-title {
	font-size: 1.6rem;
}
.post-card:hover .post-title {
	color: var(--amber);
}
.post-excerpt {
	font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
	font-size: 0.88rem;
	color: var(--text-2);
	line-height: 1.65;
	margin: 0;
	max-width: 60ch;
	display: -webkit-box;
	-webkit-line-clamp: 2;
	-webkit-box-orient: vertical;
	overflow: hidden;
}
.post-cta {
	font-family: 'JetBrains Mono', monospace;
	font-size: 0.7rem;
	color: var(--text-3);
	margin-top: auto;
	padding-top: 0.75em;
	display: inline-block;
	transition: color 0.15s ease;
}
.post-card:hover .post-cta {
	color: var(--amber);
}

/* Responsive */
@media (max-width: 780px) {
	.hero-inner {
		padding: 3.5em 1.25em 4em;
	}
	.posts-grid {
		grid-template-columns: 1fr;
	}
	.post-card--featured {
		grid-column: 1;
	}
	.post-card--featured .post-title {
		font-size: 1.35rem;
	}
	.post-card--featured .post-card-inner {
		padding: 1.75em 1.5em;
	}
	.post-card-inner {
		padding: 1.5em;
	}
}
</style>
